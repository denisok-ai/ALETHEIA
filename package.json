{
  "name": "avaterra-course",
  "version": "3.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:debug": "NODE_OPTIONS='--inspect' next dev",
    "dev:debug:seed": "npm run db:seed && npm run dev:debug",
    "dev:clean": "rm -rf .next && next dev",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "build:server": "NODE_OPTIONS='--max-old-space-size=1536' next build",
    "start": "next start",
    "start:debug": "NODE_OPTIONS='--inspect' next start",
    "lint": "next lint",
    "predeploy": "npm run lint && npm run build"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/react": "^3.0.118",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/noto-sans": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.8",
    "@react-pdf/renderer": "^4.3.2",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.116",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.4.2",
    "framer-motion": "^11.11.17",
    "grammy": "^1.41.1",
    "html-to-text": "^9.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.454.0",
    "nanoid": "^5.1.6",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-email": "^5.2.9",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^9.0.1",
    "recharts": "^3.8.0",
    "resend": "^4.0.1",
    "scorm-again": "^3.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "three": "^0.169.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
