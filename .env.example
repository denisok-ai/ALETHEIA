# Обязательные переменные (не переносятся в настройки):
# - DATABASE_URL — Prisma подключается до чтения БД
# - NEXTAUTH_SECRET — ключ шифрования секретов в БД (минимум 32 символа)

# База данных (SQLite локально; для прода — PostgreSQL)
DATABASE_URL="file:./dev.db"

# NextAuth: секрет подписи сессий (только здесь, не в админке)
NEXTAUTH_SECRET=your_random_secret_min_32_chars

# NextAuth: URL сайта (для редиректов). В dev при запуске на другом порту — задать, напр. NEXTAUTH_URL=http://localhost:3001
# NEXTAUTH_URL=http://localhost:3000

# Все остальные параметры задаются в Портал → Настройки:
# - Общие: URL сайта, название портала, контакт, макс. размер SCORM
# - Почта: Resend (from, notify), шаблоны писем об оплате
# - PayKeeper: сервер, логин, пароль, секрет (боевое и тестовое)
# - Переменные окружения: NEXTAUTH_URL, Resend API ключ, Telegram Bot Token,
#   Telegram Webhook Secret, Cron secret, OpenAI API ключ, DeepSeek API ключ
