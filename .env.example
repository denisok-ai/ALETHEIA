# Database (локальная SQLite, без Docker)
DATABASE_URL="file:./dev.db"

# PayKeeper (боевое подключение)
PAYKEEPER_SERVER=demo.server.paykeeper.ru
PAYKEEPER_LOGIN=your_login
PAYKEEPER_PASSWORD=your_password
PAYKEEPER_SECRET=your_secret_word

# PayKeeper тестовое подключение (в админке можно включить «Использовать тестовое подключение»)
# PAYKEEPER_USE_TEST=1
# PAYKEEPER_TEST_SERVER=demo.server.paykeeper.ru
# PAYKEEPER_TEST_LOGIN=test_login
# PAYKEEPER_TEST_PASSWORD=test_password
# PAYKEEPER_TEST_SECRET=test_secret

# NextAuth (обязательно для production)
NEXTAUTH_SECRET=your_random_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_URL=https://yourdomain.com

# DeepSeek (запасной вариант; основной ключ задаётся в Настройки AI)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Resend (уведомления о заявках). Можно задать в Настройки → Переменные окружения (БД)
RESEND_API_KEY=re_xxx
RESEND_FROM=notifications@yourdomain.com
RESEND_NOTIFY_EMAIL=admin@yourdomain.com

# Telegram Bot (уведомления, команды /progress, /cert, /help). Можно задать в Настройки → Переменные окружения
# TELEGRAM_BOT_TOKEN=

# Cron: защита маршрута запланированных рассылок (GET /api/cron/mailings-send). Можно задать в Настройки → Переменные окружения
# Вызывать с заголовком Authorization: Bearer <CRON_SECRET>; без переменной проверка в dev пропускается
# CRON_SECRET=

# NEXTAUTH_URL можно задать в Настройки → Переменные окружения (NEXTAUTH_SECRET — только здесь)
