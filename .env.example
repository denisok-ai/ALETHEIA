# Обязательные переменные (только здесь, не переносятся в админку):
# - DATABASE_URL — Prisma подключается до чтения БД
# - NEXTAUTH_SECRET — ключ шифрования секретов в БД (минимум 32 символа)

# База данных (SQLite локально; для прода — PostgreSQL)
DATABASE_URL="file:./dev.db"

# NextAuth: секрет подписи сессий
NEXTAUTH_SECRET=your_random_secret_min_32_chars

# Все остальные настройки задаются в Портал → Настройки (хранятся в БД):
# - Общие: URL сайта, название портала, контакт
# - Почта: Resend (from, notify), шаблоны писем об оплате
# - PayKeeper: сервер, логин, пароль, секрет (боевое и тестовое)
# - Переменные окружения: NEXTAUTH_URL, Resend API ключ, Telegram, Cron secret, OpenAI/DeepSeek API ключи
