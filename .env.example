# Обязательные переменные (только здесь, не переносятся в админку):
# - DATABASE_URL — Prisma подключается до чтения БД
# - NEXTAUTH_SECRET — ключ шифрования секретов в БД (минимум 32 символа)

# База данных (SQLite локально; для прода — PostgreSQL)
DATABASE_URL="file:./dev.db"

# NextAuth: секрет подписи сессий
NEXTAUTH_SECRET=your_random_secret_min_32_chars

# Опционально для первого старта / импорта в БД (см. Портал → Настройки → импорт из env, docs/Env-Config.md):
# NEXT_PUBLIC_URL=  RESEND_FROM=  RESEND_NOTIFY_EMAIL=  RESEND_API_KEY=
# PAYKEEPER_SERVER= PAYKEEPER_LOGIN= PAYKEEPER_PASSWORD= PAYKEEPER_SECRET=
# NEXTAUTH_URL=  # опционально: если не задан — подставляется URL сайта из БД (Портал → Настройки) или NEXT_PUBLIC_URL
# CRON_SECRET=  TELEGRAM_BOT_TOKEN=  DEEPSEEK_API_KEY=  OPENAI_API_KEY=
# PORTAL_TITLE=  COMPANY_LEGAL_ADDRESS=  CONTACT_PHONE=  SCORM_MAX_SIZE_MB=
#
# Все операционные настройки после импорта или ручного ввода хранятся в БД (Портал → Настройки).

# Публичные счётчики (опционально; на production-сборке включены по умолчанию, см. GoogleTagInHead + AnalyticsScripts)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-7CQ48S3CFF
# NEXT_PUBLIC_CLARITY_PROJECT_ID=w4v3ss4ro9
# NEXT_PUBLIC_YANDEX_VERIFICATION=0dec6f2dc03cbfd9
# Опционально: мета-тег для Google Search Console (если выбрали способ «HTML-тег»)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
