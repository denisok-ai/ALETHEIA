# Локальная отладка — Supabase Local (PostgreSQL)
# Скопируйте: cp .env.local.example .env.local
# Ключи возьмите из: npx supabase status

# Supabase Local (после npx supabase start)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<из supabase status>
SUPABASE_SERVICE_ROLE_KEY=<из supabase status>

NEXT_PUBLIC_URL=http://localhost:3000

# Опционально
PAYKEEPER_SERVER=demo.server.paykeeper.ru
PAYKEEPER_LOGIN=test
PAYKEEPER_PASSWORD=test
PAYKEEPER_SECRET=test
DEEPSEEK_API_KEY=
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
